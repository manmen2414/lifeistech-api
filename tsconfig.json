{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", // これが現在の「es系統」との黄金コンビです
    "lib": [
      "ESNext",
      "DOM"
    ],
    "allowJs": true, // JSファイルの入力を許可
    "checkJs": true, // JS内のJSDocを型チェックする
    "declaration": true, // .d.ts ファイルを出力する
    "emitDeclarationOnly": true, // 型定義ファイルのみ出力（コード本体はWebpackがやるため）
    "outDir": "./types", // 型定義ファイルの出力先
    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ] // 監視対象のソースコード
}